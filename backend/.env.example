# 客服管理平台环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============ 基础配置 ============
# JWT 密钥（务必修改！）
SECRET_KEY=change-me-in-production

# 数据库（默认 SQLite，可切换为 MySQL）
# SQLite：sqlite:///./platform.db
# MySQL：mysql+pymysql://用户名:密码@主机:3306/数据库名
DATABASE_URL=sqlite:///./platform.db

# ============ 管理员账户 ============
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============ 文件上传 ============
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ============ ChromaDB ============
CHROMA_PERSIST_DIR=./chroma_db

# ============ 前端地址（用于生成客服链接）============
FRONTEND_URL=http://localhost:5173

# ============ LLM 配置 ============
# OpenAI 兼容接口（GLM-4 等）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=zhipuai/glm-4-flash
LLM_API_KEY=your-llm-api-key-here

# 超时设置（秒）
LLM_READ_TIMEOUT=120

# ============ 邮件配置（可选）============
# MAIL_USERNAME=your-email@qq.com
# MAIL_PASSWORD=your-email-password
# MAIL_FROM=your-email@qq.com

# ============ 小红书配置（可选）============
# XHS_USERNAME=your-xhs-username
# XHS_PASSWORD=your-xhs-password

# ============ MySQL 配置（使用 MySQL 时取消注释）============
# DATABASE_URL=mysql+pymysql://cs_user:cs_pass123@localhost:3306/customer_service
